      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "cfg6t0v89osn4b" },
      "targets": [
        {
          "expr": "sum by (tier) (model_routing_total)",
