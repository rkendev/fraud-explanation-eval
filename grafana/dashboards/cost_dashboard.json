    {
      "id": 6,
      "title": "API Request Rate & Latency",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "cfg6t0v89osn4b" },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95 latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "req/s" },
            "properties": [
              { "id": "unit", "value": "reqps" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
